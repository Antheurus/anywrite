{
  "name": "anywrite",
  "version": "0.1.0",
  "module": "src/cli.ts",
  "type": "module",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Antheurus/anywrite.git"
  },
  "bin": {
    "anywrite": "./dist/anywrite"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --compile --outfile ./dist/anywrite",
    "dev": "bun --hot ./src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "check": "bun run typecheck && bun run lint",
    "codegen": "openapi-typescript spec/openapi-2025-11-08.yaml -o src/types/api.d.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/bun": "^1.3.14",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3",
    "yaml": "^2.9.0"
  }
}
